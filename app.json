{
  "expo": {
    "name": "Attenza",
    "slug": "attenza",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "attenza",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "bundleIdentifier": "com.vindra.attenza",
      "buildNumber": "1",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to secure your attendance data",
        "CFBundleLocalizations": [
          "en"
        ],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "package": "com.vindra.attenza",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "./withAndroidManifestFix",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "afda8a63-2555-4f78-96a7-d306ded825dc"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/3a04ba9e-0d30-4743-8e60-f735894d2922",
      "fallbackToCacheTimeout": 0,
      "enabled": false
    },
    "owner": "python778"
  }
}